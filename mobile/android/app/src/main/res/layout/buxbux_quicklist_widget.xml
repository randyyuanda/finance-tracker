<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="4dp"
    android:background="@drawable/widget_bg">

    <TextView
        android:id="@+id/btn_quick_exp_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="2dp"
        android:gravity="center"
        android:text="-10k"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/widget_btn_expense_alt" />

    <TextView
        android:id="@+id/btn_quick_exp_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginHorizontal="2dp"
        android:gravity="center"
        android:text="-50k"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/widget_btn_expense_alt" />

    <TextView
        android:id="@+id/btn_quick_inc_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginHorizontal="2dp"
        android:gravity="center"
        android:text="+10k"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/widget_btn_income_alt" />

    <TextView
        android:id="@+id/btn_quick_inc_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="2dp"
        android:gravity="center"
        android:text="+50k"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/widget_btn_income_alt" />

</LinearLayout>
