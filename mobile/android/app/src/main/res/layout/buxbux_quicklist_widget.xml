<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <ImageView
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="#4ECCA3"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/widget_quick_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quick Transaction"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BuxBux"
            android:textSize="9sp"
            android:textColor="#4ECCA3"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btn_quick_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_btn_expense_alt"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_quick_1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-10k"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/btn_quick_1_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expense"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_quick_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_btn_expense_alt"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_quick_2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-50k"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/btn_quick_2_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expense"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <LinearLayout
            android:id="@+id/btn_quick_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_btn_income_alt"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_quick_3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+10k"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/btn_quick_3_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Income"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_quick_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_btn_income_alt"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_quick_4_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+50k"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/btn_quick_4_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Income"
                android:textSize="8sp"
                android:textColor="#CCFFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
