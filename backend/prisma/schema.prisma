generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  googleId  String?  @unique
  avatar    String?
  isDummy   Boolean  @default(false)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  categories            Category[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  goals                 Goal[]
  reminders             Reminder[]
  adminNotifications    AdminNotification[]
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String   @default("cash")
  balance   Float    @default(0)
  currency  String   @default("IDR")
  color     String   @default("#1890ff")
  icon      String   @default("wallet")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  color     String   @default("#1890ff")
  icon      String   @default("tag")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  accountId   String
  categoryId  String
  amount      Float
  type        String
  date        DateTime @default(now())
  note        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date(sort: Desc)])
  @@index([userId, accountId])
  @@index([userId, type])
}

model RecurringTransaction {
  id         String    @id @default(cuid())
  userId     String
  accountId  String
  categoryId String
  type       String
  amount     Float
  note       String?
  frequency  String    // daily | weekly | monthly | yearly
  nextDue    DateTime
  lastRun    DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, isActive, nextDue])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  color         String    @default("#1890ff")
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Reminder {
  id           String   @id @default(cuid())
  userId       String
  title        String
  note         String?
  reminderDate DateTime
  type         String   @default("custom") // custom | bill | goal | recurring
  relatedId    String?
  isCompleted  Boolean  @default(false)
  repeatType   String   @default("none") // none | daily | weekly | monthly | yearly
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, reminderDate])
  @@index([userId, isCompleted])
}

model AdminNotification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  note        String?
  scheduledAt DateTime
  repeatType  String   @default("none") // none | daily | weekly | monthly
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
